{
    "name": "akirk/wordopedia",
    "description": "Wordopedia - A personal encyclopedia app powered by WpApp",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "akirk/wp-app": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Akirk\\Wordopedia\\": "src/"
        }
    },
    "version": "0.1.0",
    "authors": [
        {
            "name": "Alex Kirk"
        }
    ],
    "config": {
        "autoloader-suffix": "wordopedia"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit"
    }
}
