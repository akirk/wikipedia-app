{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Wikipedia App",
		"description": "Search, browse, language-switch, save, and refetch Wikipedia articles in a WpApp plugin.",
		"author": "Alex Kirk"
	},
	"landingPage": "/wikipedia/",
	"login": true,
	"steps": [
		{
			"step": "setSiteOptions",
			"options": {
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "activatePlugin",
			"pluginName": "Wikipedia App",
			"pluginPath": "wikipedia-app/wikipedia-app.php"
		}
	]
}
